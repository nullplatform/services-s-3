#!/bin/bash
# Sourceable library of PURE helpers for assume-role resolution.
# Defines functions only — NO side effects on source.
#
# NOTE: services do NOT receive CONTEXT.providers[...] populated the way scopes
# do, so (unlike the k8s/static scopes) this resolves the AWS IAM provider by
# querying the API with `np` at runtime — same model as the lambda scope.
#
# Requires (at call time): np + jq.

# arn_for_selector_from_json <provider_read_json> <selector>
# Given the JSON returned by `np provider read --id <id> --format json` and a
# selector, echoes the matching IAM role ARN, or "" if no match / malformed.
arn_for_selector_from_json() {
  local json="$1" selector="$2"
  [ -n "$json" ] || return 0
  [ -n "$selector" ] || return 0
  printf '%s' "$json" | jq -r --arg sel "$selector" '
    [ .attributes.iam_role_arns.arns[]?
      | select(.selector == $sel)
      | .arn ]
    | first // ""' 2>/dev/null
}

# provider_arn_for_selector <nrn> <selector>
# Looks up the AWS IAM provider (spec aws-iam-configuration) at <nrn>, reads it,
# and echoes the ARN matching <selector>. Empty if no provider / no match.
# `np provider list` does NOT return deep attributes, so we list to get the id
# and then `np provider read --id` for the arns.
provider_arn_for_selector() {
  local nrn="$1" selector="$2"
  [ -n "$nrn" ] || return 0
  [ -n "$selector" ] || return 0

  local pid data
  pid=$(np provider list --nrn "$nrn" \
          --specification_slug aws-iam-configuration \
          --format json --limit 100 2>/dev/null \
        | jq -r '[ (.results // [])[] ] | first | .id // ""' 2>/dev/null)
  [ -n "$pid" ] && [ "$pid" != "null" ] || return 0

  data=$(np provider read --id "$pid" --format json 2>/dev/null)
  arn_for_selector_from_json "$data" "$selector"
}

# resolve_assume_role_arn <account_nrn> <selector>
# Echoes the IAM role ARN to assume ("" = use agent credentials):
#   1. $S3_ASSUME_ROLE_ARN env var (explicit override)
#   2. AWS IAM provider (aws-iam-configuration) at <account_nrn> by <selector>
#   3. $S3_ASSUME_ROLE_ARN_DEFAULT env var (per-account agent default)
resolve_assume_role_arn() {
  local nrn="$1" selector="$2" arn=""

  arn="${S3_ASSUME_ROLE_ARN:-}"

  if [ -z "$arn" ] && [ -n "$nrn" ] && [ -n "$selector" ]; then
    arn=$(provider_arn_for_selector "$nrn" "$selector")
  fi

  arn="${arn:-${S3_ASSUME_ROLE_ARN_DEFAULT:-}}"
  printf '%s' "$arn"
}
