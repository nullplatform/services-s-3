#!/bin/bash
# Dedicated workflow step: resolve the target IAM role and assume it, exporting
# temporary credentials so every subsequent step (including tofu) inherits them.
#
# Runs FIRST in each AWS-touching workflow. The workflow YAML must declare
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY and AWS_SESSION_TOKEN as
# output:environment so the engine propagates them downstream.
#
# Services do NOT receive CONTEXT.providers[...] like scopes, so the role is
# resolved by querying the AWS IAM provider with `np` at the account NRN
# (see resolve_assume_role_arn in assume_role_lib). Precedence:
#   $S3_ASSUME_ROLE_ARN -> IAM provider by selector -> $S3_ASSUME_ROLE_ARN_DEFAULT -> IRSA
#
# Requires: aws CLI, jq, np. Expects: CONTEXT (engine-injected), SERVICE_PATH,
#           SERVICE_ID (optional, session name).

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/assume_role_lib"

# Account NRN from CONTEXT (service / scope / generic event), stripping the
# :namespace= segment and everything after it — the IAM provider is account-level.
NRN=$(echo "${CONTEXT:-}" | jq -r '.service.nrn // .scope.nrn // .entity_nrn // ""' 2>/dev/null)
ACCOUNT_NRN=$(echo "$NRN" | sed 's/:namespace=.*$//')
S3_ASSUME_ROLE_SELECTOR="${S3_ASSUME_ROLE_SELECTOR:-s3}"

S3_ASSUME_ROLE_ARN=$(resolve_assume_role_arn "$ACCOUNT_NRN" "$S3_ASSUME_ROLE_SELECTOR")
export S3_ASSUME_ROLE_ARN

# utils/assume_role performs sts:AssumeRole and exports AWS_* when an ARN is set,
# or no-ops (leaving agent credentials in place) when empty. Non-zero only when
# sts:AssumeRole itself fails.
if ! source "$SCRIPT_DIR/assume_role"; then
  echo "   ❌ assume_role step failed: could not assume $S3_ASSUME_ROLE_ARN" >&2
  echo "" >&2
  echo "💡 Possible causes:" >&2
  echo "   • The agent's role is not allowed to sts:AssumeRole the target role" >&2
  echo "   • The target role does not exist or does not trust the agent role" >&2
  echo "   • There is no role ARN configured for selector=$S3_ASSUME_ROLE_SELECTOR at $ACCOUNT_NRN" >&2
  echo "" >&2
  exit 1
fi
