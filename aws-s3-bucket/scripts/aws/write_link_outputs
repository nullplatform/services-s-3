#!/bin/bash
set -euo pipefail

# ---------------------------------------------------------------------------
# write_link_outputs — Reads Terraform outputs from the permissions module
# and writes them to the NP link attributes via the API.
#
# Fields with "export: environment_variable" become env vars (plain).
# Fields with "export: {secret: true}" are encrypted at rest but injected
# into the app at runtime.
# ---------------------------------------------------------------------------

cd "$OUTPUT_DIR"

LINK_ID_VAL=$(echo "$CONTEXT" | jq -r '.link.id')

echo "Reading Terraform outputs for link $LINK_ID_VAL..."

AWS_ACCESS_KEY_ID=$(tofu output -raw aws_access_key_id 2>/dev/null || echo "")
AWS_SECRET_ACCESS_KEY=$(tofu output -raw aws_secret_access_key 2>/dev/null || echo "")
IAM_USER_NAME=$(tofu output -raw iam_user_name 2>/dev/null || echo "")

if [ -z "$AWS_ACCESS_KEY_ID" ]; then
  echo "WARNING: No aws_access_key_id output found. Skipping link attribute update."
  exit 0
fi

# Only persist attributes unique to the link. bucket_name and region are
# already exposed by the service itself (see service-spec.json.tpl) — keeping
# them here would duplicate the env vars injected into linked apps.
ATTRS=$(jq -n \
  --arg access_key_id     "$AWS_ACCESS_KEY_ID" \
  --arg secret_access_key "$AWS_SECRET_ACCESS_KEY" \
  --arg iam_user_name     "$IAM_USER_NAME" \
  '{
    aws_access_key_id:     $access_key_id,
    aws_secret_access_key: $secret_access_key,
    iam_user_name:         $iam_user_name
  }')

echo "Updating link $LINK_ID_VAL attributes:"
echo "  aws_access_key_id:     $AWS_ACCESS_KEY_ID"
echo "  aws_secret_access_key: ****"
echo "  iam_user_name:         $IAM_USER_NAME"

np link patch --id "$LINK_ID_VAL" --body "{\"attributes\": $ATTRS}"
echo "Link attributes updated successfully."
